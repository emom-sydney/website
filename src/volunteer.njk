---
layout: "main.njk"
pageTitle: "Volunteer Registration"
description: "Register as an EMOM volunteer and claim event roles such as sound, VJ, door, stagehand, MC, and catering."
---
<h2>Volunteer Registration</h2>

<div id="volunteer-registration-app" class="performer-registration">
  <section id="volunteer-registration-start" class="performer-registration-panel">
    <p>
      Enter your email address and we will send you a one-time link to create or update your volunteer profile
      and claim roles for upcoming events.
    </p>
    <form id="volunteer-registration-start-form">
      <label for="volunteer-registration-email">Email address</label>
      <input type="email" id="volunteer-registration-email" name="email" required>
      <button type="submit">Send registration link</button>
    </form>
  </section>

  <section id="volunteer-registration-session" class="performer-registration-panel" hidden>
    <p>
      Choose one or more event role claims. If a role is already full for a date, your claim will be placed on standby.
      If a selected volunteer cancels, the oldest standby claim is promoted automatically.
    </p>

    <form id="volunteer-registration-session-form">
      <label for="volunteer-email-display">Email address</label>
      <input type="email" id="volunteer-email-display" readonly>

      <label class="performer-registration-checkbox">
        <input type="checkbox" id="volunteer-is-email-public" name="is_email_public">
        <span>Show email on your crew profile page</span>
      </label>

      <label for="volunteer-display-name">Display name</label>
      <input type="text" id="volunteer-display-name" name="display_name" required>

      <label for="volunteer-first-name">First name</label>
      <input type="text" id="volunteer-first-name" name="first_name">

      <label for="volunteer-last-name">Last name</label>
      <input type="text" id="volunteer-last-name" name="last_name">

      <label class="performer-registration-checkbox">
        <input type="checkbox" id="volunteer-is-name-public" name="is_name_public">
        <span>Show full name on your crew profile page</span>
      </label>

      <label for="volunteer-contact-phone">Contact phone number</label>
      <input type="text" id="volunteer-contact-phone" name="contact_phone" required>
      <p class="performer-registration-note">Not shown publicly. Used if we need to contact you urgently on event day.</p>

      <label for="volunteer-bio">Volunteer bio (visible on crew profile)</label>
      <textarea id="volunteer-bio" name="volunteer_bio" rows="6"></textarea>

      <label for="volunteer-additional-info">Additional info (not shown on profile)</label>
      <textarea id="volunteer-additional-info" name="additional_info" rows="4" placeholder="Share anything useful for scheduling, accessibility, logistics, etc."></textarea>

      <fieldset class="performer-registration-fieldset">
        <legend>Social links</legend>
        <div id="volunteer-social-links"></div>
        <button type="button" id="volunteer-add-social-link">Add social link</button>
      </fieldset>

      <fieldset class="performer-registration-fieldset">
        <legend>Claim volunteer roles</legend>
        <p class="performer-registration-note">Select every role/date you are available for. Filled roles will become standby claims.</p>
        <p class="performer-registration-note">Event date</p>
        <div id="volunteer-event-tabs" class="volunteer-event-tabs" role="tablist" aria-label="Event dates"></div>
        <p id="volunteer-selected-claims-note" class="performer-registration-note"></p>
        <div id="volunteer-role-claims"></div>
      </fieldset>

      <fieldset class="performer-registration-fieldset">
        <legend>Claim ongoing volunteer roles</legend>
        <p class="performer-registration-note">These roles are not tied to a specific event date.</p>
        <div id="volunteer-general-role-claims"></div>
      </fieldset>

      <button type="submit">Submit volunteer registration</button>
    </form>
  </section>

</div>

<script src="/assets/scripts/volunteer_registration_form.js"></script>
