---
layout: "main.njk"
pageTitle: "Perform"
---

<div class="workflow-stack">
  <section class="workflow-card">
    <h2>Register interest to perform</h2>
    <p class="workflow-lead">Use this form for a specific event. We will email you a private link so you can confirm later, withdraw, or update details without needing an account.</p>

    <form id="perform-interest-form" class="workflow-form">
      <label>Name
        <input type="text" name="name" autocomplete="name" required>
      </label>

      <label>Stage name
        <input type="text" name="stageName" autocomplete="nickname">
      </label>

      <label>Email
        <input type="email" name="email" autocomplete="email" required>
      </label>

      <label>Mobile
        <input type="text" name="mobile" autocomplete="tel" required>
      </label>

      <label>Event
        <select name="eventId" required>
          <option value="">Choose an event</option>
          {% for event in events %}
          <option value="{{ event.ID }}">{{ event.EventName }}{% if event.Date %} ({{ event.Date }}){% endif %}</option>
          {% endfor %}
        </select>
      </label>

      <label>Short set description
        <textarea name="setDescription" rows="4" required></textarea>
      </label>

      <label>Gear / setup notes
        <textarea name="gearNotes" rows="3"></textarea>
      </label>

      <label>Link
        <input type="url" name="socials" placeholder="https://">
      </label>

      <button type="submit">Send interest</button>
    </form>

    <div id="perform-interest-status" class="workflow-status" aria-live="polite"></div>
  </section>

  <section class="workflow-card workflow-card-muted">
    <h2>What happens next</h2>
    <ul class="workflow-list">
      <li>You submit interest for one event.</li>
      <li>Organisers review it in a queue.</li>
      <li>You receive an email with a private manage link.</li>
      <li>From that link you can confirm, withdraw, request changes, or edit your details.</li>
    </ul>
  </section>
</div>

<script>
  window.__WORKFLOW_CONFIG = {
    apiBase: {{ workflowConfig.apiBase | dump | safe }}
  };
</script>
<script type="module" src="/assets/js/perform-interest.js"></script>
