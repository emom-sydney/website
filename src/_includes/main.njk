<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ siteName }} | {{ pageTitle }}</title>
  {% set metaDescription = description or siteDescription or 'Sydney EMOM - Electronic Music Open Mic' %}
  <meta name="description" content="{{ metaDescription }}">
  <meta property="og:site_name" content="{{ siteName }}">
  <meta property="og:title" content="{{ siteName }} | {{ pageTitle }}">
  <meta property="og:description" content="{{ metaDescription }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:url" content="{{ siteUrl }}{{ page.url }}">
  {% set metaImage = ogImage or '/assets/img/emom-social.png' %}
  {% if metaImage and (metaImage.startsWith('http') or metaImage.startsWith('//')) %}
    {% set fullMetaImage = metaImage %}
  {% else %}
    {% set fullMetaImage = siteUrl + metaImage %}
  {% endif %}
  <meta property="og:image" content="{{ fullMetaImage }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ siteName }} | {{ pageTitle }}">
  <meta name="twitter:description" content="{{ metaDescription }}">
  <meta name="twitter:image" content="{{ fullMetaImage }}">
  <link rel="canonical" href="{{ siteUrl }}{{ page.url }}">
  <link rel="stylesheet" type="text/css" href="/assets/css/style.css">
  <script src="/assets/scripts/toast.js"></script>
  <style>
    /* fallback and variable used for background image */
    :root {
      --bg-image-url: none;
    }
  </style>
  <script>
    // Read 11ty data: bgimages (array of relative paths) and bgBase (base URL string).
    const _bgImages = {{ bgimages | dump | safe }};
    const _bgBase = {{ bg_img_baseurl | dump | safe }};
    (function () {
      if (!Array.isArray(_bgImages) || !_bgImages.length) return;
      const base = (typeof _bgBase === 'string') ? _bgBase.replace(/\/+$/, '') : '';
      const chosenRel = String(_bgImages[Math.floor(Math.random() * _bgImages.length)] || "");
      const rel = chosenRel.replace(/^\/+/, '');
      const full = base ? `${base}/${rel}` : rel;
      const encoded = encodeURI(full);
      document.documentElement.style.setProperty('--bg-image-url', `url("${encoded}")`);
    })();
  </script>
</head>
<body>
  {% include "page_header.njk" %}
  <div class="main_content">
    {% include "page_sidebar.njk" %}
    <div class="page_body">
      {{ content | safe }}    
    </div>
  </div>
  <div id="toast-root" class="toast-stack" aria-live="polite" aria-atomic="true"></div>
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-grid">
      <div class="mobile-menu-column">
        <h2 class="mobile-menu-heading">Explore</h2>
        <nav class="mobile-menu-nav" aria-label="Main navigation">
          {% include "nav_main.njk" %}
        </nav>
      </div>
      <div class="mobile-menu-column">
        <h2 class="mobile-menu-heading">Get Involved</h2>
        <nav class="mobile-menu-nav" aria-label="Get involved">
          {% include "nav_involved.njk" %}
          {% include "nav_external.njk" %}
        </nav>
      </div>
    </div>
    <div class="mobile-menu-social">
      {% include "social_links.njk" %}
    </div>
  </div>
  {% include "page_footer.njk" %}
  <script>
    (function () {
      var toggle = document.querySelector('.menu-toggle');
      var menu = document.getElementById('mobile-menu');
      if (!toggle || !menu) return;

      var scrollY = 0;

      toggle.addEventListener('click', function () {
        var expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        menu.classList.toggle('nav-open', !expanded);
        menu.setAttribute('aria-hidden', String(expanded));
        document.body.classList.toggle('menu-open', !expanded);

        if (!expanded) {
          // Opening menu: lock scroll and save position
          scrollY = window.scrollY;
          document.body.style.position = 'fixed';
          document.body.style.top = '-' + scrollY + 'px';
          document.body.style.width = '100%';
        } else {
          // Closing menu: unlock scroll and restore position
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.width = '';
          window.scrollTo(0, scrollY);
        }
      });
    })();
  </script>
</body>
</html>