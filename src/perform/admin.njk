<h2>Performer Admin</h2>

<p>Use this page to organise acts for an upcoming Open Mic date.</p>

<form id="performer-admin-start-form">
  <label for="performer-admin-event">Date to edit</label>
  <select id="performer-admin-event" name="event_id" required>
    <option value="">Loading upcoming dates...</option>
  </select>

  <label for="performer-admin-email">Enter your email address (must be a site admin)</label>
  <input type="email" id="performer-admin-email" name="email" required>

  <button type="submit">Send admin link</button>
</form>

<script>
  (function () {
    const form = document.getElementById("performer-admin-start-form");
    const eventSelect = document.getElementById("performer-admin-event");
    const emailInput = document.getElementById("performer-admin-email");

    function setStatus(message, kind) {
      const text = String(message || "").trim();
      if (!text) return;
      if (typeof window.showToast === "function") {
        window.showToast(text, { kind: kind || "info" });
      }
    }

    function extractToken(value) {
      const text = String(value || "").trim();
      if (!text) return "";
      try {
        const url = new URL(text);
        return url.searchParams.get("token") || "";
      } catch (_) {
        return text;
      }
    }

    function openToken(token) {
      if (!token) {
        setStatus("A valid admin token is required.", "error");
        return;
      }
      window.location.assign(`/api/forms/performer-registration/admin-selection?token=${encodeURIComponent(token)}`);
    }

    async function loadEvents() {
      setStatus("Loading upcoming event dates...");
      try {
        const response = await fetch("/api/forms/performer-registration/admin-selection/events");
        const result = await response.json();
        if (!response.ok || !result.ok) {
          throw new Error(result.error || "Unable to load event dates.");
        }

        const events = result.events || [];
        eventSelect.innerHTML = "";
        if (!events.length) {
          eventSelect.innerHTML = "<option value=\"\">No upcoming Open Mic dates available</option>";
          eventSelect.disabled = true;
          return;
        }

        eventSelect.disabled = false;
        eventSelect.innerHTML = "<option value=\"\">Choose a date...</option>";
        for (const eventItem of events) {
          const option = document.createElement("option");
          option.value = String(eventItem.event_id);
          option.textContent = `${eventItem.event_date} - ${eventItem.event_name}`;
          eventSelect.appendChild(option);
        }
      } catch (error) {
        eventSelect.innerHTML = "<option value=\"\">Unable to load event dates</option>";
        eventSelect.disabled = true;
        setStatus(error.message || "Unable to load event dates.", "error");
      }
    }

    const queryToken = new URLSearchParams(window.location.search).get("token");
    if (queryToken) {
      openToken(queryToken);
      return;
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const email = String(emailInput?.value || "").trim();
      const eventId = Number.parseInt(eventSelect?.value || "0", 10);

      if (!/^\S+@\S+\.\S+$/.test(email)) {
        setStatus("Please enter a valid admin email address.", "error");
        return;
      }
      if (!(eventId > 0)) {
        setStatus("Please choose an event date.", "error");
        return;
      }

      setStatus("Sending admin link...");
      try {
        const response = await fetch("/api/forms/performer-registration/admin-selection/start", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            email,
            event_id: eventId,
          }),
        });
        const result = await response.json();
        if (!response.ok || !result.ok) {
          throw new Error(result.error || "Unable to send admin link.");
        }
        setStatus(result.message || "If the email belongs to a site admin, a fresh link has been sent.", "success");
      } catch (error) {
        setStatus(error.message || "Unable to send admin link.", "error");
      }
    });

    loadEvents();
  }());
</script>
